# Backend (Node/Express)
# Copy to .env in project root or backend/

NODE_ENV=development
PORT=3001

# PostgreSQL (Railway provides DATABASE_URL in production)
DATABASE_URL=postgresql://localhost:5432/clirdec

# Auth
JWT_SECRET=change-me-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# Validation (optional) — 7-second window per spec
#VALIDATION_WINDOW_MS=7000
#PROXIMITY_MAX_CM=80
# Grace period (minutes) for Present; after grace = Late; after 60% session = invalid
#GRACE_PERIOD_MINUTES=10
#LATE_CUTOFF_PCT=60
