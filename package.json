{
  "name": "clirdec-presence",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "CLIRDEC: Presence-Proximity and RFID-Enabled Smart Entry for Notation of Classroom Engagement",
  "scripts": {
    "setup": "npm install && npm run db:migrate",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && node scripts/copy-public.js && npm run build:backend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "node backend/dist/index.js",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:backup": "node scripts/db-backup.js",
    "preflight": "node scripts/preflight.js",
    "create-admin": "node scripts/create-first-admin.js",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "postinstall": "cd backend && npm install && cd ../frontend && npm install"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.2",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
